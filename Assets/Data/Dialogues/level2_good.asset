  dialogueLines:
  - speakerName: Student
    speakerPortrait: {fileID: 0}
    speakerLine: Wow kuya, ang galing niyo naman po! Para kanino po kayo umuusad?
    voiceSound: {fileID: 0}
    voicePitch: 0
  - speakerName: You
    speakerPortrait: {fileID: 0}
    speakerLine: Salamat, gusto ko lang humingi ng konting tulong para sa pamilya
      ko...
    voiceSound: {fileID: 0}
    voicePitch: 0
  - speakerName: You
    speakerPortrait: {fileID: 0}
    speakerLine: Wala na kami na kasi kami makain.
    voiceSound: {fileID: 0}
    voicePitch: 0
  - speakerName: 
    speakerPortrait: {fileID: 0}
    speakerLine: The student eagerly hands you enough earnings to live off the next
      few days.
    voiceSound: {fileID: 0}
    voicePitch: 0
  - speakerName: You
    speakerPortrait: {fileID: 0}
    speakerLine: Maraming salamat po.
    voiceSound: {fileID: 0}
    voicePitch: 0
  - speakerName: Student
    speakerPortrait: {fileID: 0}
    speakerLine: Grabe naman kayo kuya ang sipag niyo naman!
    voiceSound: {fileID: 0}
    voicePitch: 0
